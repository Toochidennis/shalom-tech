# Local environment and secrets
.env
.env.*
!.env.example
/config/app.php
/app/Config/core.php
/app/Config/database.php

# Dependencies and package-manager caches
vendor/
vendors/
node_modules/
.composer/
.npm/

# Logs and runtime output
*.log
logs/
/logs/*
!/logs/empty
tmp/
temp/
/tmp/cache/models/*
!/tmp/cache/models/empty
/tmp/cache/persistent/*
!/tmp/cache/persistent/empty
/tmp/cache/views/*
!/tmp/cache/views/empty
/tmp/sessions/*
!/tmp/sessions/empty
/tmp/tests/*
!/tmp/tests/empty
/app/tmp/*

# Generated screenshots and test artifacts
_shots/
coverage/

# Editor and OS metadata
.DS_Store
Thumbs.db
.idea/
.vscode/

# Codex/agent local state
.agents/
.codex/
