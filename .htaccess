# =============================================================================
# Shalom Academy Nsukka — Apache config (SEO + performance + safety)
# Every block is guarded by <IfModule> so it degrades gracefully if a module
# is unavailable. Apache + AllowOverride required. Remove/adjust on other stacks.
# =============================================================================

DirectoryIndex index.php
Options -Indexes

# --- Clean (extensionless) URLs + HTTPS canonicalisation ----------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # http -> https (stay on the same host; never bounce to another domain)
    RewriteCond %{HTTPS} off
    RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # 1) Redirect direct .php requests to their clean URL (GET only, so form
    #    POSTs to e.g. process.php are never redirected and keep their body).
    RewriteCond %{REQUEST_METHOD} =GET
    RewriteCond %{THE_REQUEST} \s/+([^.\s?]+)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L,NE]

    # 2) Internally serve /about from about.php (no redirect, URL stays clean).
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.+?)/?$ $1.php [L]
</IfModule>

# --- Compression --------------------------------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json
    AddOutputFilterByType DEFLATE application/xml image/svg+xml
</IfModule>

# --- Browser caching (faster repeat visits = better Core Web Vitals) ----------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType text/html               "access plus 0 seconds"
</IfModule>

# --- Security / quality headers ----------------------------------------------
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# --- Correct MIME type for the web manifest -----------------------------------
<IfModule mod_mime.c>
    AddType application/manifest+json .webmanifest
</IfModule>
